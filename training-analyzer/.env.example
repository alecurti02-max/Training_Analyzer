# ===== Server =====
NODE_ENV=development
PORT=3000

# ===== Database =====
# Local dev (Docker PostgreSQL):
DATABASE_URL=postgres://ta_user:ta_pass@localhost:5432/training_analyzer

# Production (Neon) — set in the Render/host dashboard, NOT here:
# DATABASE_URL=postgres://user:password@ep-xxx.eu-central-1.aws.neon.tech/training_analyzer?sslmode=require

# ===== JWT =====
JWT_SECRET=change-me-to-random-64-chars
JWT_REFRESH_SECRET=change-me-to-another-random-64-chars

# ===== Google OAuth2 =====
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ===== Client =====
CLIENT_ORIGIN=http://localhost:3000

# ===== Firebase (solo per script migrazione) =====
FIREBASE_DATABASE_URL=https://training-analyzer-deb1f-default-rtdb.europe-west1.firebasedatabase.app
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
